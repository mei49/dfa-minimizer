import torch
import torch.nn as nn

# 1. DEFINE THE BRAIN (Neural Network Architecture)
class EmotionNet(nn.Module):
    def __init__(self):
        super(EmotionNet, self).__init__()
        # Linear layer: takes 2 inputs (Freq, Amp), outputs to 5 hidden neurons
        self.hidden = nn.Linear(2, 5) 
        # Output layer: takes 5 neurons, outputs 1 result (Probability)
        self.output = nn.Linear(5, 1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        x = torch.relu(self.hidden(x))
        x = self.sigmoid(self.output(x))
        return x

# 2. IMPLEMENT THE MODEL
model = EmotionNet()

# 3. PREPARE INPUT (PyTorch uses "Tensors" instead of Lists)
# New subject data: [31.0 Hz frequency, 1.3 amplitude]
new_subject = torch.tensor([[31.0, 1.3]], dtype=torch.float32)

# 4. PREDICT
# Switch to evaluation mode
model.eval()
with torch.no_grad():
    prediction = model(new_subject)

print(f"--- Level 3: PyTorch Deep Learning Implementation ---")
print(f"Raw Neural Network Output: {prediction.item():.4f}")
print(f"Prediction: {'Depressed' if prediction.item() > 0.5 else 'Normal'}")